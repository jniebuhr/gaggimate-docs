---
import { Image } from "astro:assets";

/**
 * LIGHTBOX COMPONENT
 *
 * Displays a thumbnail image that opens a full-size modal on click.
 *
 * PROPS:
 * - src (required): Imported image object or string URL.
 * - alt (required): Alt text. Also shown as modal caption unless hideCaption is true.
 * - width (default: 300): Thumbnail width in pixels.
 * - priority (default: false): Use eager loading for above-the-fold images.
 * - hideCaption (default: false): Suppress alt text caption in the modal.
 * - caption: Text shown below the thumbnail (credits, notes).
 *     WARNING: Clipped if Lightbox is inside an overflow-hidden container.
 *
 * USAGE:
 *   <Lightbox src={myImage} alt="Description" />
 *   <Lightbox src={myImage} alt="Description" width={400} priority caption="Credit: Someone" />
 *
 * MODAL:
 * - Click thumbnail to open
 * - Click backdrop or X to close
 * - Tab cycles focus between close button and open-original link
 */

const {
  src,
  alt,
  width = 300,
  priority = false,
  hideCaption = false,
  caption,
} = Astro.props;

if (!src) throw new Error("Lightbox: src prop is required");

const isImageObject = typeof src === "object" && "src" in src;
const imageSrc = isImageObject ? (src as { src: string }).src : (src as string);
---

<div class="lightbox-wrapper inline-block group relative">
  <div class="relative overflow-hidden rounded-lg transition-all duration-300 group-hover:shadow-md group-hover:scale-[1.02]">
    {isImageObject ? (
      <Image
        src={src}
        alt={alt}
        width={width}
        class="trigger-open block cursor-zoom-in w-full h-full object-cover object-center my-0"
        loading={priority ? "eager" : "lazy"}
        decoding="async"
      />
    ) : (
      <img
        src={src}
        alt={alt}
        class="trigger-open block cursor-zoom-in w-full h-full object-cover object-center my-0"
        loading={priority ? "eager" : "lazy"}
        decoding="async"
      />
    )}
  </div>
</div>

<dialog
  role="dialog"
  aria-modal="true"
  aria-label="Image lightbox"
  class="image-modal"
>
  <div class="lightbox-overlay">
    <div class="lightbox-controls">
      <button
        class="lightbox-btn"
        type="button"
        aria-label="Close dialog"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <a
        href={imageSrc}
        target="_blank"
        rel="noopener"
        class="lightbox-btn"
        aria-label="Open original image"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" />
        </svg>
      </a>
    </div>

    <div class="lightbox-content">
      {isImageObject ? (
        <Image
          src={src}
          alt={alt}
          class="lightbox-image"
          loading="eager"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          class="lightbox-image"
        />
      )}

      {alt && !hideCaption && (
        <p class="lightbox-caption">{alt}</p>
      )}
    </div>
  </div>
</dialog>

{caption && (
  <span class="block text-sm text-gray-500 italic opacity-80 -mt-1 mb-2">
    {caption}
  </span>
)}

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;

    if (target.closest(".trigger-open")) {
      const wrapper = target.closest(".lightbox-wrapper");
      const dialog = wrapper?.nextElementSibling as HTMLDialogElement;
      dialog?.showModal();
    }

    const dialog = target.closest("dialog");
    if (
      dialog &&
      (target.closest('[aria-label="Close dialog"]') || target === dialog)
    ) {
      dialog.close();
    }
  });

  document.addEventListener("keydown", (e) => {
    const dialog = document.querySelector("dialog[open]") as HTMLDialogElement;
    if (!dialog || e.key !== "Tab") return;

    const focusable = dialog.querySelectorAll("button, a[href]");
    const first = focusable[0] as HTMLElement;
    const last = focusable[focusable.length - 1] as HTMLElement;

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>

<style>
  /* Reset all browser dialog defaults and force full viewport coverage */
  .image-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    outline: none;
    opacity: 0;
    display: none;
    transition:
      opacity 0.2s ease-out,
      display 0.2s ease-out allow-discrete;
  }

  .image-modal[open] {
    opacity: 1;
    display: flex;
  }

  @starting-style {
    .image-modal[open] {
      opacity: 0;
    }
  }

  /* Full-screen overlay with background */
  .lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100vw;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(2px);
    pointer-events: none;
  }

  /* Top-right controls */
  .lightbox-controls {
    position: fixed;
    top: 1rem;
    right: 1rem;
    display: flex;
    flex-direction: row-reverse;
    gap: 1rem;
    pointer-events: auto;
  }

  .lightbox-btn {
    color: rgba(255, 255, 255, 0.6);
    background: transparent;
    border: none;
    padding: 0.5rem;
    border-radius: 9999px;
    cursor: pointer;
    outline: none;
    transition: color 0.15s;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-btn:hover {
    color: white;
  }

  .lightbox-btn:focus-visible {
    outline: 2px solid white;
    outline-offset: -6px;
    border-radius: 9999px;
  }

  /* Image and caption */
  .lightbox-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
  }

  .lightbox-image {
    max-height: 70dvh;
    max-width: 90vw;
    width: auto;
    height: auto;
    border-radius: 0.75rem;
  }

  .lightbox-caption {
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
    max-width: 42rem;
  }
</style>
