<div
  id="toc-wrapper"
  class="fixed right-0 top-1/2 -translate-y-1/2 z-40 flex items-center justify-end"
>
  <!-- Tab button — fixed to right edge, vertically centered -->
  <button
    id="toc-toggle"
    aria-label="Table of contents"
    aria-expanded="false"
    class="flex items-center justify-center w-8 h-16 bg-black text-white rounded-l-lg shadow-lg hover:bg-gray-800 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-white/30"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h10"></path>
    </svg>
  </button>

  <!-- Sliding panel — hidden by default, shown on toggle click -->
  <div
    id="toc-panel"
    class="absolute right-full mr-1 w-max min-w-48 max-w-80 max-w-[calc(100vw-4rem)] bg-white border border-gray-200 rounded-lg shadow-xl overflow-hidden translate-x-4 opacity-0 pointer-events-none transition-all duration-300"
    aria-hidden="true"
  >
    <!--
      Title: defaults to "Contents" but is replaced at runtime with the page's h1 text.
      See buildToc() below.
    -->
    <div class="px-4 py-3 border-b border-gray-100">
      <p
        id="toc-title"
        class="text-xs font-semibold uppercase tracking-widest text-gray-400"
      >
        Contents
      </p>
    </div>

    <!-- Nav links are injected here by buildToc() -->
    <nav id="toc-nav" class="max-h-[60vh] overflow-y-auto py-2"></nav>
  </div>
</div>

<script>
  (() => {
    let isOpen = false;
    let closeOnOutsideClick: ((e: MouseEvent) => void) | null = null;
    // Stored so we can disconnect it on page navigation to prevent memory leaks
    let headingObserver: IntersectionObserver | null = null;

    /**
     * Scrapes all h2 headings from the page and builds the TOC nav links.
     *
     * FILTERING:
     * - Headings inside #toc-wrapper itself are excluded (avoids self-reference).
     * - Headings with the `toc-ignore` attribute are excluded.
     *   Usage in MDX: <h2 toc-ignore>Heading</h2>
     *
     * STRIPPING:
     * - Any element inside a heading with `data-toc-strip` will be removed
     *   from the TOC link text only (the heading on the page is unaffected).
     *   Usage: wrap text you want hidden from TOC in <span data-toc-strip>...</span>
     *   Example: ## <Tokens type="eu" icon><span data-toc-strip>EU Only</span></Tokens> Section Title
     *   Result in TOC: "🇪🇺 Section Title"
     *
     * ACTIVE STATE:
     * - An IntersectionObserver highlights the TOC link for the heading
     *   currently nearest the top of the viewport.
     * - rootMargin accounts for the 65px sticky header offset.
     */
    function buildToc() {
      const nav = document.getElementById("toc-nav");
      if (!nav) return;

      // Disconnect previous observer before rebuilding to prevent stacking
      if (headingObserver) {
        headingObserver.disconnect();
        headingObserver = null;
      }

      nav.innerHTML = "";

      // Replace "Contents" label with the page's h1 title if available
      const title = document.querySelector("h1")?.textContent?.trim();
      const tocTitle = document.getElementById("toc-title");
      if (tocTitle && title) tocTitle.textContent = title;

      const headings = Array.from(
        document.querySelectorAll<HTMLHeadingElement>("h2"),
      ).filter(
        (h) =>
          h.textContent?.trim() &&
          !document.getElementById("toc-wrapper")?.contains(h) &&
          !h.hasAttribute("toc-ignore"),
      );

      if (headings.length === 0) {
        nav.innerHTML = `<p class="px-4 py-2 text-sm text-gray-400 italic">No headings found.</p>`;
        return;
      }

      // Highlights the TOC link for the heading nearest the top of the viewport
      headingObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              nav
                .querySelectorAll("a")
                .forEach((a) =>
                  a.classList.remove(
                    "text-black",
                    "font-semibold",
                    "bg-gray-100",
                  ),
                );
              nav
                .querySelector(`a[href="#${entry.target.id}"]`)
                ?.classList.add("text-black", "font-semibold", "bg-gray-100");
            }
          });
        },
        // Negative top margin accounts for sticky header; bottom margin
        // ensures only the topmost visible heading is highlighted
        { rootMargin: "-65px 0px -80% 0px" },
      );

      headings.forEach((heading) => {
        // Auto-generate an id from heading text if one isn't already set
        if (!heading.id) {
          heading.id = heading
            .textContent!.trim()
            .toLowerCase()
            .replace(/[^\w\s-]/g, "")
            .replace(/\s+/g, "-");
        }

        const a = document.createElement("a");
        a.href = `#${heading.id}`;

        // Clone the heading to safely strip data-toc-strip elements
        // without mutating the actual DOM
        const headingClone = heading.cloneNode(true) as HTMLElement;
        headingClone
          .querySelectorAll("[data-toc-strip]")
          .forEach((el) => el.remove());
        a.textContent = headingClone.textContent?.trim() ?? "";

        a.className =
          "block px-4 py-1.5 text-sm font-medium text-gray-600 hover:text-black hover:bg-gray-50 transition-colors duration-150 line-clamp-2";

        // Close the drawer and scroll to heading on click
        a.addEventListener("click", (e) => {
          e.preventDefault();
          closeToc();
          document
            .getElementById(heading.id)
            ?.scrollIntoView({ behavior: "smooth" });
        });

        nav.appendChild(a);
        headingObserver!.observe(heading);
      });
    }

    function openToc() {
      const panel = document.getElementById("toc-panel");
      const toggle = document.getElementById("toc-toggle");
      if (!panel || !toggle) return;

      isOpen = true;
      panel.classList.remove(
        "translate-x-4",
        "opacity-0",
        "pointer-events-none",
      );
      panel.classList.add("translate-x-0", "opacity-100");
      panel.setAttribute("aria-hidden", "false");
      toggle.setAttribute("aria-expanded", "true");

      // Close when clicking outside the TOC wrapper
      closeOnOutsideClick = (e: MouseEvent) => {
        const wrapper = document.getElementById("toc-wrapper");
        if (wrapper && !wrapper.contains(e.target as Node)) {
          closeToc();
        }
      };
      document.addEventListener("click", closeOnOutsideClick);
    }

    function closeToc() {
      const panel = document.getElementById("toc-panel");
      const toggle = document.getElementById("toc-toggle");
      if (!panel || !toggle) return;

      isOpen = false;
      panel.classList.add("translate-x-4", "opacity-0", "pointer-events-none");
      panel.classList.remove("translate-x-0", "opacity-100");
      panel.setAttribute("aria-hidden", "true");
      toggle.setAttribute("aria-expanded", "false");

      if (closeOnOutsideClick) {
        document.removeEventListener("click", closeOnOutsideClick);
        closeOnOutsideClick = null;
      }
    }

    function init() {
      const toggle = document.getElementById("toc-toggle");
      if (!toggle) return;

      // Clone the toggle button to remove any stale event listeners
      // from previous page loads (Astro view transitions)
      const newToggle = toggle.cloneNode(true) as HTMLElement;
      toggle.replaceWith(newToggle);

      newToggle.addEventListener("click", (e) => {
        e.stopPropagation();
        isOpen ? closeToc() : openToc();
      });

      buildToc();
    }

    // Re-initialize on every Astro page navigation
    document.addEventListener("astro:page-load", init);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    // Clean up before Astro swaps the page to prevent memory leaks
    document.addEventListener("astro:before-swap", () => {
      if (headingObserver) {
        headingObserver.disconnect();
        headingObserver = null;
      }
      if (closeOnOutsideClick) {
        document.removeEventListener("click", closeOnOutsideClick);
        closeOnOutsideClick = null;
      }
      isOpen = false;
    });
  })();
</script>
